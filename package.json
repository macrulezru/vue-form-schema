{
  "name": "vue-form-schema",
  "version": "0.1.0",
  "description": "Reactive forms from JSON/Zod/Yup schema with validation, masking and conditional UI for Vue 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./zod": {
      "import": "./dist/zod.js",
      "require": "./dist/zod.cjs",
      "types": "./dist/zod.d.ts"
    },
    "./yup": {
      "import": "./dist/yup.js",
      "require": "./dist/yup.cjs",
      "types": "./dist/yup.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs",
      "types": "./dist/ui.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "demo": "vite --config vite.demo.config.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "yup": "^1.3.0",
    "zod": "^3.22.0"
  }
}
