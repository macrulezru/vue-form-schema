{
  "name": "@macrulez/vue-form-schema",
  "version": "0.1.8",
  "description": "Reactive Vue 3 forms generated from JSON, Zod, Yup or Valibot schemas, with validation, input masking, conditional UI and SSR support.",
  "author": "macrulez <macrulezru@gmail.com> (https://macrulez.ru/en)",
  "license": "MIT",
  "homepage": "https://github.com/macrulezru/vue-form-schema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macrulezru/vue-form-schema.git"
  },
  "bugs": {
    "url": "https://github.com/macrulezru/vue-form-schema/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js",
      "require": "./dist/zod.cjs"
    },
    "./yup": {
      "types": "./dist/yup.d.ts",
      "import": "./dist/yup.js",
      "require": "./dist/yup.cjs"
    },
    "./valibot": {
      "types": "./dist/valibot.d.ts",
      "import": "./dist/valibot.js",
      "require": "./dist/valibot.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./ui/tailwind": {
      "types": "./dist/ui-tailwind.d.ts",
      "import": "./dist/ui-tailwind.js",
      "require": "./dist/ui-tailwind.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "demo": "vite --config vite.demo.config.ts",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "form",
    "schema",
    "validation",
    "zod",
    "yup",
    "valibot",
    "mask",
    "ssr",
    "typescript"
  ],
  "peerDependencies": {
    "vue": "^3.3.0",
    "zod": ">=3.22.0",
    "yup": ">=1.3.0",
    "valibot": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "valibot": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "valibot": "^1.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "yup": "^1.3.0",
    "zod": "^3.22.0"
  }
}
