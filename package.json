{
  "name": "@macrulez/vue-form-schema",
  "version": "0.1.6",
  "description": "Reactive forms from JSON/Zod/Yup/Valibot schema with validation, masking and conditional UI for Vue 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./zod": {
      "import": "./dist/zod.js",
      "require": "./dist/zod.cjs",
      "types": "./dist/zod.d.ts"
    },
    "./yup": {
      "import": "./dist/yup.js",
      "require": "./dist/yup.cjs",
      "types": "./dist/yup.d.ts"
    },
    "./valibot": {
      "import": "./dist/valibot.js",
      "require": "./dist/valibot.cjs",
      "types": "./dist/valibot.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs",
      "types": "./dist/ui.d.ts"
    },
    "./ui/tailwind": {
      "import": "./dist/ui-tailwind.js",
      "require": "./dist/ui-tailwind.cjs",
      "types": "./dist/ui-tailwind.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "demo": "vite --config vite.demo.config.ts",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "form",
    "schema",
    "validation",
    "zod",
    "yup",
    "composable",
    "mask",
    "reactive"
  ],
  "author": "macrulez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/macrulezru/vue-form-schema"
  },
  "homepage": "https://macrulez.ru/en",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "valibot": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "valibot": "^1.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "yup": "^1.3.0",
    "zod": "^3.22.0"
  }
}
